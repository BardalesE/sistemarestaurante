# ============================================================
# ARCHIVO DE CONFIGURACIÓN PARA PRODUCCIÓN
# Renombra este archivo a .env en el servidor
# NUNCA subas este archivo a GitHub
# ============================================================

APP_NAME="Mi Restaurante"
APP_ENV=production
APP_KEY=                         # <-- Generado con: php artisan key:generate
APP_DEBUG=false
APP_URL=https://tudominio.com    # <-- Tu dominio real (con https)

APP_LOCALE=es
APP_FALLBACK_LOCALE=es

# ============================================================
# LOGS: Solo errores importantes, no todo
# ============================================================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# ============================================================
# BASE DE DATOS: Datos del hosting
# ============================================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=nombre_bd_en_hosting  # <-- El que creaste en cPanel/Hostinger
DB_USERNAME=usuario_bd            # <-- Usuario de la BD en hosting
DB_PASSWORD=ContraseñaFuerte123!  # <-- Contraseña fuerte

# ============================================================
# SESIONES: Más seguras
# ============================================================
SESSION_DRIVER=database
SESSION_LIFETIME=480              # 8 horas (un turno completo)
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true

# ============================================================
# CACHÉ
# ============================================================
CACHE_STORE=database
QUEUE_CONNECTION=database
FILESYSTEM_DISK=public

# ============================================================
# ADMIN INICIAL (usado solo al ejecutar php artisan db:seed)
# ============================================================
ADMIN_NAME="Tu Nombre"
ADMIN_EMAIL=tuemail@tudominio.com
ADMIN_PASSWORD=ContraseñaSuperSegura456!

# ============================================================
# CORREO (opcional, para notificaciones futuras)
# Si usas Gmail, activa "contraseñas de app" en Google
# ============================================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tucorreo@gmail.com
MAIL_PASSWORD=contraseña_de_app_google
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=tucorreo@gmail.com
MAIL_FROM_NAME="Mi Restaurante"
